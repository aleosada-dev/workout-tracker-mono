{
  "name": "workout-tracker-mono",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "lefthook install",
    "postinstall": "node scripts/fix-expo-macros-symlink.js"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "lefthook": "^2.1.9",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "react-native-css-interop": "0.2.4"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=20"
  },
  "patchedDependencies": {
    "react-native-reanimated-dnd@2.0.0": "patches/react-native-reanimated-dnd@2.0.0.patch"
  }
}
