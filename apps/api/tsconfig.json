{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"types": ["bun"],
		"paths": {
			"@/*": ["./src/*"]
		},
		"moduleResolution": "Bundler",
		"strict": true,
		"skipLibCheck": true,
		"lib": ["ESNext"],
		"jsx": "react-jsx",
		"jsxImportSource": "hono/jsx"
	},
	"exclude": ["node_modules", "supabase"]
}
