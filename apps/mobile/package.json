{
  "name": "workout-tracker-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "APP_VARIANT=development expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "APP_VARIANT=development expo run:android",
    "ios": "APP_VARIANT=development expo run:ios",
    "web": "APP_VARIANT=development expo start --web",
    "prebuild:dev": "APP_VARIANT=development expo prebuild --clean",
    "prebuild:preview": "APP_VARIANT=preview expo prebuild --clean",
    "prebuild:prod": "APP_VARIANT=production expo prebuild --clean",
    "update:dev": "eas update --branch development",
    "update:preview": "eas update --branch preview --environment preview && npx sentry-expo-upload-sourcemaps dist",
    "update:prod": "eas update --branch production --environment production --auto && npx sentry-expo-upload-sourcemaps dist",
    "build:preview:android": "eas build --profile preview --platform android --local --output builds/preview-android.apk",
    "build:preview:ios": "eas build --profile preview-simulator --platform ios --local --output builds/preview-ios-simulator.tar.gz",
    "submit:preview": "eas submit --profile preview-store --platform all --latest",
    "submit:preview:ios": "eas submit --profile preview-store --platform ios --latest",
    "submit:preview:android": "eas submit --profile preview-store --platform android --latest",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "check:ci": "biome ci .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:e2e": "bash .maestro/run.sh",
    "postinstall": "lefthook install"
  },
  "dependencies": {
    "@expo-google-fonts/geist": "^0.4.1",
    "@expo-google-fonts/geist-mono": "^0.4.1",
    "@expo/ui": "~56.0.13",
    "@expo/vector-icons": "^15.0.2",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@hookform/resolvers": "^5.2.2",
    "@legendapp/state": "^3.0.0-beta.47",
    "@rn-primitives/accordion": "^1.4.0",
    "@rn-primitives/alert-dialog": "^1.4.0",
    "@rn-primitives/checkbox": "^1.4.0",
    "@rn-primitives/dialog": "^1.4.0",
    "@rn-primitives/label": "^1.4.0",
    "@rn-primitives/popover": "^1.4.0",
    "@rn-primitives/portal": "^1.4.0",
    "@rn-primitives/select": "^1.4.0",
    "@rn-primitives/separator": "^1.4.0",
    "@rn-primitives/slot": "^1.4.0",
    "@rn-primitives/switch": "^1.4.0",
    "@rn-primitives/tabs": "^1.4.0",
    "@rn-primitives/toggle": "^1.4.0",
    "@rn-primitives/toggle-group": "^1.4.0",
    "@sentry/react-native": "~7.11.0",
    "@shopify/flash-list": "2.0.2",
    "@shopify/react-native-skia": "2.6.2",
    "@supabase/supabase-js": "^2.105.3",
    "@tanstack/react-query": "^5.100.9",
    "@workout-tracker/api-types": "workspace:*",
    "@workout-tracker/application": "workspace:*",
    "@workout-tracker/domain": "workspace:*",
    "@workout-tracker/infrastructure": "workspace:*",
    "@workout-tracker/ui-mobile": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "expo": "^56.0.4",
    "expo-constants": "~56.0.15",
    "expo-crypto": "~56.0.3",
    "expo-dev-client": "~56.0.15",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-glass-effect": "~56.0.4",
    "expo-image": "~56.0.9",
    "expo-image-picker": "~56.0.13",
    "expo-linking": "~56.0.11",
    "expo-localization": "~56.0.6",
    "expo-notifications": "~56.0.13",
    "expo-router": "~56.2.6",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.16",
    "expo-video": "~56.1.2",
    "expo-video-thumbnails": "~56.0.3",
    "expo-web-browser": "~56.0.5",
    "hono": "^4.12.18",
    "i18next": "^26.0.10",
    "lucide-react-native": "^1.14.0",
    "nativewind": "^4.2.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.75.0",
    "react-i18next": "^17.0.7",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.6",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-toast-message": "^2.3.3",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3",
    "react-native-youtube-iframe": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "victory-native": "^41.20.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.14",
    "@workout-tracker/typescript-config": "workspace:*",
    "babel-preset-expo": "~56.0.0",
    "fast-text-encoding": "^1.0.6",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.4",
    "lefthook": "^2.1.6",
    "msw": "^2.14.5",
    "react-query-external-sync": "^2.2.3",
    "react-test-renderer": "19.2.3",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~6.0.3"
  },
  "private": true,
  "patchedDependencies": {
    "react-native-css-interop@0.2.4": "patches/react-native-css-interop@0.2.4.patch"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "roots": [
      "<rootDir>/src",
      "<rootDir>/../../packages/ui-mobile/src"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/src/features/test-utils/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|@rn-primitives/.*|@react-native/js-polyfills|msw|@mswjs/.*|rettime|until-async|@open-draft/.*|headers-polyfill|type-fest)"
    ],
    "transform": {
      "^.+\\.mjs$": "babel-jest"
    }
  },
  "trustedDependencies": [
    "@sentry/cli",
    "@shopify/react-native-skia"
  ]
}
